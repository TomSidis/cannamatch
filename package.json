{
  "name": "cannamatch",
  "private": true,
  "version": "7.0.0",
  "type": "module",
  "description": "קנאמאצ׳ — מלווה אישי לקנאביס רפואי בישראל. התאמת זנים לפי גנטיקה וטרפנים, פירוק תפריטים, וקהילה.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node api/server.js",
    "db:up": "docker compose up -d",
    "db:init": "node api/db/initDb.js",
    "db:seed": "node api/db/seedStrains.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  }
}
