# ─────────────────────────────────────────────────────────────
#  קנאמאצ׳ — משתני סביבה. העתק לקובץ .env ומלא ערכים אמיתיים.
#  לעולם אל תעלה את .env ל-Git! (הוא ב-.gitignore)
# ─────────────────────────────────────────────────────────────

# סביבה. בפרודקשן חובה 'production' — מפעיל הגשת ה-SPA + אכיפת CORS + בדיקות fail-fast.
NODE_ENV=production

# פורט השרת (ברירת מחדל 8787 בפיתוח; אצל המארח לרוב מוזרק אוטומטית, למשל 5000/10000).
PORT=8787

# ── סודות חובה לפרודקשן (השרת מסרב לעלות בלעדיהם ב-NODE_ENV=production) ──

# JWT_SECRET — חתימת טוקני התחברות. גנרציה:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# SERVER_HMAC_SECRET — HMAC-SHA256 של מספרי רישיון (ייחודיות קהילה). גנרציה:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# אסור לאפס בפרודקשן — ישבור את כל מפתחות הייחודיות הקיימים.
SERVER_HMAC_SECRET=

# DATABASE_URL — Postgres מנוהל. פורמט:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# דורש את התוספים vector + pgcrypto + pg_trgm (ראו README, שלב המסד).
DATABASE_URL=

# PRODUCTION_ORIGIN — דומיין הפרודקשן המלא, למשל https://cannamatch.onrender.com
# חובה ב-production (CORS לא יכול להיות wildcard). בפריסת מקור-יחיד זהו אותו דומיין של ה-API.
PRODUCTION_ORIGIN=

# ── אופציונלי ──

# ANTHROPIC_API_KEY — לא נדרש למסלול הליבה (OCR/פירוק/דירוג רצים מקומית).
# מלא רק אם מפעילים פיצ'רים שתלויים ב-LLM. קבל ב-https://console.anthropic.com
ANTHROPIC_API_KEY=

# GOOGLE_PLACES_KEY — אופציונלי, לרענון שעות בתי מרקחת ב-cron היומי.
GOOGLE_PLACES_KEY=

# ADMIN_EMAIL + ADMIN_INITIAL_PASSWORD — אתחול חשבון אדמין ראשוני (אידמפוטנטי, ראו adminBootstrap).
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
