# מפתח ה-API של Anthropic — קבל אותו ב-https://console.anthropic.com
# חשוב: לעולם אל תעלה את הקובץ .env האמיתי ל-Git! (הוא ב-.gitignore)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# פורט לשרת ה-proxy (ברירת מחדל 8787)
PORT=8787

# דומיין הפרודקשן — חובה למלא לפני deploy (למשל: https://cannamatch.co.il).
# השרת לא יעלה לאוויר ב-NODE_ENV=production אם הערך ריק.
PRODUCTION_ORIGIN=

# מפתח סודי לחישוב HMAC-SHA256 של מספרי רישיון (Phase C1 — Community).
# גנרציה מומלצת: node -e "require('crypto').randomBytes(32).toString('hex')"
# אסור לאפס ערך זה בפרודקשן — ישבור את כל בדיקות הייחודיות הקיימות.
# אסור לחשוף ל-client, לא ב-bundle, לא ב-log.
SERVER_HMAC_SECRET=
